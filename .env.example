# iSportsAPI Configuration
YOUR_API_KEY=your_isportsapi_key_here

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Custom API endpoints
# BASE_URL=http://api.isportsapi.com
# MIRROR_URL=http://api2.isportsapi.com

# Optional: Probability thresholds
# UMBRAL_PROBABILIDAD=85.0
# TOP_N_TELEGRAM=5
# TOP_N_MARKDOWN=50

# Optional: Rate limiting (seconds between calls)
# RATE_LIMIT_SECONDS=10
# REQUEST_TIMEOUT=30